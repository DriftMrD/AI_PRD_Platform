# ============================================================
# PRD Forge Backend - 环境变量模板
# ============================================================
# 使用方法：
#   1) 本地开发：cp .env.example .env  ← 真实 key 填到 .env
#   2) 生产部署：在 Render/Railway 控制台的 Environment 里填同样这些 key
#
# ⚠️  永远不要把 .env 提交到 git！（.gitignore 已屏蔽）
# ⚠️  永远不要把 LLM_API_KEY 写进前端 JS / GitHub Pages 配置！
#     浏览器会裸奔展示给所有访问者。
# ============================================================

# ----- LLM（OpenAI 兼容协议，可换 provider） -----
# DeepSeek（推荐，国内直连，便宜）
LLM_PROVIDER=openai
LLM_API_KEY=sk-你的-deepseek-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=20000

# OpenAI 官方（注释掉上面三行，改用下面）
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-你的-openai-key
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# 智谱 GLM
# LLM_API_KEY=your-zhipu-key
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_MODEL=glm-4-flash

# 超时（秒）
LLM_TIMEOUT_S=180
LLM_FIRST_TOKEN_TIMEOUT_S=30

# ----- 文件 / 解析 -----
MAX_FILE_SIZE_MB=20
MAX_FILE_CHARS=50000

# ----- CORS -----
# 逗号分隔。生产环境务必加上 GitHub Pages 域名：
#   https://<user>.github.io
# 本地开发保留 localhost。
CORS_ORIGINS=http://localhost:5173,http://localhost:8000,http://127.0.0.1:8000,https://driftmrd.github.io

# ----- Langfuse Prompt Management（可选） -----
# 配齐下面两个 key 后，后端从 Langfuse 拉取 SKILL / 模板，而不是读本地文件。
# 免费 Hobby 档：https://cloud.langfuse.com
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
# LANGFUSE_SKILL_DOCUMENT_PROMPT_NAME=prd-skill-document
# LANGFUSE_SKILL_DIALOGUE_PROMPT_NAME=prd-skill-dialogue
# LANGFUSE_TEMPLATE_PROMPT_NAME=prd-template
# LANGFUSE_SYSTEM_PROMPT_NAME=prd-system
#   prd-system 的 Config JSON 可在线改 model / temperature / max_tokens
# LANGFUSE_PROMPT_LABEL=production
# LANGFUSE_CACHE_TTL_SECONDS=60
