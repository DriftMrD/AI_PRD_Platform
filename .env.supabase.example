# Supabase 一键配置凭证（复制为 .env.supabase 后填入，不要提交 git）
# 获取方式见 docs/SUPABASE_SETUP.md

# 必填：Project Settings → API（或 Integrations → API Keys）
# 新版 Supabase 叫 Publishable key（sb_publishable_...），等同于旧版 anon key
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_PUBLISHABLE_OR_ANON_KEY

# 必填：Account → Access Tokens → Generate new token
# https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_YOUR_PERSONAL_ACCESS_TOKEN

# 可选：从 URL 自动解析；填了可跳过
# SUPABASE_PROJECT_REF=your_project_ref

# 可选：Auth 站点 URL（默认线上登录页）
SUPABASE_SITE_URL=https://driftmrd.github.io/AI_PRD_Platform/login.html
SUPABASE_REDIRECT_URLS=https://driftmrd.github.io/AI_PRD_Platform/**,http://localhost:5173/**,http://127.0.0.1:5173/**
